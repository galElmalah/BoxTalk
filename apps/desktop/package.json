{
  "name": "@boxtalk/app",
  "version": "0.1.1",
  "private": true,
  "description": "BoxTalk Electron app — local TTS using Kokoro / VibeVoice",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite build && electron .",
    "build:vibevoice": "node scripts/build-vibevoice.mjs",
    "dist:mac": "vite build && electron-builder --mac",
    "smoke": "vite build && node tests/smoke.mjs",
    "e2e": "vite build && node tests/e2e.mjs",
    "test": "pnpm run smoke && pnpm run e2e"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.49.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.1",
    "kokoro-js": "^1.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "build": {
    "appId": "ai.boxtalk.app",
    "productName": "BoxTalk",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "vibevoice.js",
      "kokoroClient.js",
      "kokoro-worker.js",
      "styles.css",
      "package.json",
      "dist/**/*",
      "!**/*.map",
      "!tests/**/*",
      "!scripts/**/*",
      "!**/.cache/**",
      "!vendor/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "icon": "build/icon.png"
    },
    "npmRebuild": false
  }
}
